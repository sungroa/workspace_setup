# make less more friendly for non-text input files, see lesspipe(1).
# Lesspipe provides intelligent text rendering when using `less` on binary files or archives.
# Lazy-load to avoid subshell fork penalty on shell startup.
if [ -x /usr/bin/lesspipe ]; then
    less() {
        eval "$(SHELL=/bin/sh lesspipe)"
        command less "$@"
    }
fi

# Enable color support of ls and also add handy aliases.
# `dircolors` configures semantic color values based on file types mimicking modern term capabilities.
if [ -x /usr/bin/dircolors ]; then
    if [ ! -f ~/.dircolors_cache ] || [ ~/.dircolors -nt ~/.dircolors_cache 2>/dev/null ]; then
        test -r ~/.dircolors && dircolors -b ~/.dircolors > ~/.dircolors_cache || dircolors -b > ~/.dircolors_cache
    fi
    source ~/.dircolors_cache

    alias ls='ls --color=auto'

    alias grep='grep --color=auto'
    alias fgrep='fgrep --color=auto'
    alias egrep='egrep --color=auto'
fi

# Keep aliases in a different file for easy viewing.
if [ -f ~/.bash_aliases ]; then
    . ~/.bash_aliases
fi

# Vi style prompt input
# Enables modal editing directly on the command line for vim power-users.
set -o vi

# Done to make Windows connect to XMing Display Environment correctly.
# Map DISPLAY to the local Windows machine's X-Server.
# Only set it if it isn't already dynamically provided (e.g., organically by WSLg or Wayland)
# to avoid breaking modern GUI integrations.
if [ -z "$DISPLAY" ]; then
    export DISPLAY=:0
fi
